# Frontend (Vite) — Supabase deste projeto (VagaMatch), dedicado, separado do automacao-vagas pessoal
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# @username público do bot (sem o @) — usado só pra montar o link t.me/<bot>?start=<token> de
# vínculo automático do Telegram no onboarding. Não é segredo, mas some o botão se não setado.
VITE_TELEGRAM_BOT_USERNAME=

# NÃO existe VITE_GEMINI_API_KEY: a chave do Gemini usada pelo frontend (gerador de CV/carta e
# importação de currículo em PDF) vive só como secret da Edge Function `gemini`, nunca no bundle
# do cliente. Ver "Edge Function do Gemini" no README para configurar via
# `supabase secrets set GEMINI_API_KEY=...`.

# Worker (Node, pipeline multi-usuário) — mesmas variáveis do automacao-vagas, mas
# SUPABASE_SERVICE_ROLE_KEY aqui é a SECRET KEY (não a publishable/anon acima).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=

# Opcional — chat_id de admin pra receber alerta se o worker falhar de forma fatal
ADMIN_TELEGRAM_CHAT_ID=
